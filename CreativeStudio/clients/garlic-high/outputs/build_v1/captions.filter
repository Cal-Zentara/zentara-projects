drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='HOW DO YOU MAKE':fontsize=90:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.75:enable='between(t,0.0,1.0)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='RAMEN UNFORGETTABLE?':fontsize=80:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.75:enable='between(t,1.0,2.0)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='ONE WORD.':fontsize=95:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.75:enable='between(t,2.0,2.6)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='GARLIC.':fontsize=240:fontcolor=#FFD700:box=1:boxcolor=black@0.85:boxborderw=30:x=(w-text_w)/2:y=h*0.68:enable='between(t,2.6,3.9)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='INTRODUCING':fontsize=90:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.75:enable='between(t,3.9,4.7)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='JIRO-STYLE':fontsize=200:fontcolor=#FFD700:box=1:boxcolor=black@0.85:boxborderw=28:x=(w-text_w)/2:y=h*0.69:enable='between(t,4.7,5.6)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='EXTRA-THICK NOODLES':fontsize=80:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.75:enable='between(t,5.6,6.5)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='RICH PORK BROTH':fontsize=85:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.75:enable='between(t,6.5,7.4)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='FRESH GARLIC':fontsize=90:fontcolor=#FFD700:box=1:boxcolor=black@0.8:boxborderw=20:x=(w-text_w)/2:y=h*0.72:enable='between(t,7.4,8.3)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='ZERO RESTRAINT.':fontsize=95:fontcolor=#FFD700:box=1:boxcolor=black@0.85:boxborderw=20:x=(w-text_w)/2:y=h*0.78:enable='between(t,8.3,9.4)',drawtext=fontfile=C\\:/Windows/Fonts/Impact.ttf:text='OR, BROTHLESS':fontsize=90:fontcolor=#